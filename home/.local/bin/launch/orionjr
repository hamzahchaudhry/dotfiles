#!/bin/sh
set -eu

REAL_HOME="${HOME}"
REAL_XDG_DATA_HOME="${XDG_DATA_HOME:-$REAL_HOME/.local/share}"

APP_NAME="orionjr2utility"
APP_ROOT="$REAL_XDG_DATA_HOME/$APP_NAME"
FAKE_HOME="$APP_ROOT/home"
APP_CACHE="$FAKE_HOME/.cache"
APP_CONFIG="$FAKE_HOME/.config"
APP_DATA="$FAKE_HOME/.local/share"
APP_STATE="$FAKE_HOME/.local/state"
APPDIR="$REAL_HOME/.local/opt/$APP_NAME"

mkdir -p \
  "$APP_ROOT" \
  "$APP_CACHE/tmp" \
  "$APP_CONFIG/java-prefs" \
  "$APP_DATA" \
  "$APP_STATE"

export HOME="$FAKE_HOME"
export XDG_CONFIG_HOME="$APP_CONFIG"
export XDG_CACHE_HOME="$APP_CACHE"
export XDG_DATA_HOME="$APP_DATA"
export XDG_STATE_HOME="$APP_STATE"
export TMPDIR="$APP_CACHE/tmp"

cd "$APPDIR" || exit 1

exec archlinux-java-run -- \
  -Duser.home="$FAKE_HOME" \
  -Djava.io.tmpdir="$APP_CACHE/tmp" \
  -Djava.util.prefs.userRoot="$APP_CONFIG/java-prefs" \
  -Dawt.useSystemAAFontSettings=on \
  -Dswing.aatext=true \
  -jar "./JrApp.jar" "$@"
