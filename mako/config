sort=-time
layer=overlay
anchor=top-right

width=360
height=110
margin=16
padding=12

border-size=2
border-radius=16
border-color=#b4befe

background-color=#11111bcc
text-color=#cdd6f4

font=JetBrainsMono Nerd Font 11
markup=1
format=<span size="large"><b>%s</b></span>\n%b

icons=1
max-icon-size=42
icon-path=/usr/share/icons/Papirus-Dark:/usr/share/icons/Papirus:/usr/share/pixmaps

default-timeout=4500
ignore-timeout=1
max-visible=4

[urgency=low]
border-color=#a6e3a1

[urgency=normal]
border-color=#fab387

[urgency=high]
border-color=#f38ba8
default-timeout=0

[category=on]
default-timeout=800
group-by=category
border-color=#a6e3a1

[category=off]
default-timeout=800
group-by=category
border-color=#f38ba8

