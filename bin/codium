#!/bin/sh
set -eu

REAL_HOME="/home/hamzah"
REAL_XDG_STATE_HOME="${XDG_STATE_HOME:-$REAL_HOME/.local/state}"

CODIUM_ROOT="$REAL_XDG_STATE_HOME/codium"
CODIUM_HOME="$CODIUM_ROOT/home"
CODIUM_XDG="$CODIUM_ROOT/xdg"
CODIUM_XDG_CONFIG="$CODIUM_XDG/config"
CODIUM_XDG_CACHE="$CODIUM_XDG/cache"
CODIUM_XDG_DATA="$CODIUM_XDG/data"
CODIUM_XDG_STATE="$CODIUM_XDG/state"
CODIUM_USER_DATA="$CODIUM_ROOT/profile/user-data"
CODIUM_EXTENSIONS="$CODIUM_ROOT/extensions"
CODIUM_TMP="$CODIUM_XDG_CACHE/tmp"

mkdir -p \
  "$CODIUM_HOME" \
  "$CODIUM_XDG_CONFIG" \
  "$CODIUM_XDG_CACHE" \
  "$CODIUM_XDG_DATA" \
  "$CODIUM_XDG_STATE" \
  "$CODIUM_TMP" \
  "$CODIUM_EXTENSIONS" \
  "$CODIUM_USER_DATA"

export HOME="$CODIUM_HOME"
export XDG_CONFIG_HOME="$CODIUM_XDG_CONFIG"
export XDG_CACHE_HOME="$CODIUM_XDG_CACHE"
export XDG_DATA_HOME="$CODIUM_XDG_DATA"
export XDG_STATE_HOME="$CODIUM_XDG_STATE"
export TMPDIR="$CODIUM_TMP"

exec /usr/bin/codium \
  --user-data-dir "$CODIUM_USER_DATA" \
  --extensions-dir "$CODIUM_EXTENSIONS" \
  "$@"
