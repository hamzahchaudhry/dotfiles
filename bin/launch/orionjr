#!/bin/sh
XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

APP_NAME="orionjr2utility"
APP_DATA="$XDG_DATA_HOME/$APP_NAME"
APP_CACHE="$XDG_CACHE_HOME/$APP_NAME"
APP_CONFIG="$XDG_CONFIG_HOME/$APP_NAME"
APPDIR="$HOME/.local/opt/$APP_NAME"

mkdir -p "$APP_DATA/home" "$APP_CACHE/tmp" "$APP_CONFIG/java-prefs"

cd "$APPDIR" || exit 1

exec archlinux-java-run -- \
  -Duser.home="$APP_DATA/home" \
  -Djava.io.tmpdir="$APP_CACHE/tmp" \
  -Djava.util.prefs.userRoot="$APP_CONFIG/java-prefs" \
  -Dawt.useSystemAAFontSettings=on \
  -Dswing.aatext=true \
  -jar "./JrApp.jar" "$@"
